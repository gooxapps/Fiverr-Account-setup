{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Fiverr Gig Generator AI",
  "version": "1.0.0",
  "identifier": "com.gooxai.fiverrgiggenerator",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Fiverr Gig Generator AI",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIwQjdGNkM3QTFFQzNEMQpSV1RSd3g1NmJIOExBaXlHbHBwTHQwTjdXa0FtaGIvcU1DQjNMaExiYXVRUTR5d2k5Y05HMVJ2Vgo=",
      "endpoints": [
        "https://github.com/gooxapps/Fiverr-Account-setup/releases/latest/download/latest.json"
      ]
    }
  }
}